# Get your API key from https://app.pinecone.io/
PINECONE_API_KEY=your-api-key-here

# Project directory to index and search (only this directory is used). Optional if you always pass --project-dir.
# PINECONE_PROJECT_DIR=/path/to/your/project

# Spend guardrail: script blocks when estimated usage reaches this (dollars). Default 10.
PINECONE_SPEND_LIMIT=10

# Set to yes to allow usage beyond PINECONE_SPEND_LIMIT (explicit permission required).
# PINECONE_ALLOW_OVER_LIMIT=yes

# Optional: for Chat (LLM-summarized answers). Get key from https://platform.openai.com/
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
