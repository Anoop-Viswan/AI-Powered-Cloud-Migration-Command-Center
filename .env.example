# Admin area: when both are set, /admin requires login (username + password). Session cookie, 24h.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-strong-password

# Get your API key from https://app.pinecone.io/
PINECONE_API_KEY=your-api-key-here

# Project directory to index and search (only this directory is used). Optional if you always pass --project-dir.
# PINECONE_PROJECT_DIR=/path/to/your/project

# Spend guardrail: script blocks when estimated usage reaches this (dollars). Default 10.
PINECONE_SPEND_LIMIT=10

# Set to yes to allow usage beyond PINECONE_SPEND_LIMIT (explicit permission required).
# PINECONE_ALLOW_OVER_LIMIT=yes

# LLM provider: openai (default), anthropic, azure_openai. All Chat and Assessment agents use this.
# LLM_PROVIDER=openai

# OpenAI (default). Get key from https://platform.openai.com/
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.3
# OPENAI_MAX_TOKENS=4096
# OPENAI_SYSTEM_PROMPT=Your custom system prompt here. If unset, a default CoE assistant prompt is used.

# Anthropic (when LLM_PROVIDER=anthropic). Requires: pip install langchain-anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Azure OpenAI (when LLM_PROVIDER=azure_openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Optional: LangSmith observability (full trace trees, token usage, cost in LangSmith UI).
# Get API key from https://smith.langchain.com/ → Settings → API Keys. Then uncomment and set:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxx
# LANGCHAIN_PROJECT=assessment

# Optional: Use LLM for profile validation (extra API call before research). Rule-based validation always runs.
# PROFILE_VALIDATION_USE_LLM=yes

# Profile content validation: flag placeholder/nonsense values (e.g. "I don't know", "good") across all fields.
# Set to true (default) to use LLM; rules-based check always runs. Set to false to skip LLM content check.
# PROFILE_CONTENT_VALIDATION_USE_LLM=true

# Research flow: KB confidence and official-doc search (see docs/RESEARCH_FLOW_BLUEPRINT.md)
# Min Pinecone score to count a hit as "strong" for confidence. Default 0.5.
# RESEARCH_KB_MIN_SCORE=0.5
# Below this confidence (0–1) we run official-doc web search. Default 0.35.
# RESEARCH_KB_CONFIDENCE_LOW=0.35
# Set to false to disable official-doc search even when confidence is low.
# RESEARCH_OFFICIAL_DOCS_ENABLED=true
# Tavily API key for web search (official docs). Get key from https://app.tavily.com/ If unset, official-doc step is skipped.
# TAVILY_API_KEY=tvly-...
